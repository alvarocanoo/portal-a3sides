# ===========================================
# Portal a3sides - Variables de entorno
# ===========================================
# Copia este archivo como .env.local y rellena los valores

# --- Base de datos ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portal_a3sides?schema=public"

# --- NextAuth ---
# Genera con: openssl rand -base64 32 (o node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="CAMBIAR_POR_SECRETO_SEGURO"
AUTH_URL="http://localhost:3000"

# --- Email (SMTP) ---
# Deja vacío para modo consola (los emails se imprimen en el log del servidor)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Portal a3sides <noreply@a3sides.es>"

# --- Almacenamiento de archivos ---
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB="10"

# --- Cifrado de datos sensibles ---
# Genera con: openssl rand -hex 32 (o node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY="CAMBIAR_POR_CLAVE_32_BYTES_HEX"

# --- iRecursos (integracion) ---
IRECURSOS_BASE_URL=""
IRECURSOS_AUTH_TOKEN=""
IRECURSOS_TIMEOUT_MS="10000"
