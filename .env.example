# ===========================================
# Portal a3sides - Variables de entorno
# ===========================================
# Copia este archivo como .env.local y rellena los valores.
#
# AVISO PARA PRODUCCIÓN
# ---------------------
# Cuando NODE_ENV=production, el portal valida al arrancar
# (src/lib/env-check.ts vía src/instrumentation.ts) que las variables
# esenciales estén bien configuradas y ABORTA el arranque si no lo
# están. Las variables marcadas con [REQUERIDA EN PROD] son
# obligatorias y deben tener valores reales (no placeholders) en
# despliegues de producción.
# ===========================================

# --- Base de datos ---
# [REQUERIDA EN PROD]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portal_a3sides?schema=public"

# --- NextAuth ---
# [REQUERIDA EN PROD] — Genera uno seguro con:
#   openssl rand -base64 32
#   (o)  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Si se despliega en producción con el valor placeholder ("CAMBIAR_*"),
# cualquiera puede falsificar sesiones JWT. El portal aborta si lo detecta.
AUTH_SECRET="CAMBIAR_POR_SECRETO_SEGURO"

# [REQUERIDA EN PROD] — URL pública del portal. La usan los emails para
# construir enlaces Y NextAuth para resolver redirecciones (logout,
# callbackUrl). Si apunta a localhost en producción, el portal aborta —
# salvo que ALLOW_LOCAL_PROD esté activado (ver más abajo).
AUTH_URL="http://localhost:3000"

# === MODO DEMO LOCAL ==========================================
# Para arrancar el portal con `npm run build && npm start` EN TU MÁQUINA
# (para una demo, prueba de prod build, etc.), el env-check normalmente
# abortaría porque AUTH_URL apunta a localhost. Para ese caso activa:
#
#   ALLOW_LOCAL_PROD="true"
#
# Con esta variable activa:
#   - Se ACEPTA AUTH_URL=http://localhost:3000 (logout y redirecciones
#     de auth funcionan contra localhost en lugar de un dominio falso).
#   - Se imprime un banner muy visible al arranque para que sea
#     evidente que NO estás en una producción real.
#   - El RESTO de validaciones siguen estrictas: AUTH_SECRET debe ser
#     real (no placeholder), SMTP configurado, DATABASE_URL definida.
#
# NUNCA actives ALLOW_LOCAL_PROD=true en una producción real / pública —
# los clientes recibirían emails con enlaces a localhost.
ALLOW_LOCAL_PROD=""
# ==============================================================

# --- Email (SMTP) ---
# [REQUERIDA EN PROD] — Sin SMTP, los emails (invitaciones, resets de
# contraseña, notificaciones de incidencias) caerían a console.log y
# los clientes NUNCA recibirían nada. El portal aborta en producción
# si SMTP_HOST está vacío.
#
# En desarrollo, deja SMTP_HOST="" para usar modo consola (los emails
# se imprimen en el log del servidor).
SMTP_HOST=""
SMTP_PORT="587"
# [REQUERIDA EN PROD si SMTP_HOST]
SMTP_USER=""
# [REQUERIDA EN PROD si SMTP_HOST]
SMTP_PASS=""
SMTP_FROM="Portal a3sides <noreply@a3sides.es>"

# --- Almacenamiento de archivos ---
# AVISO PARA PRODUCCIÓN: la ruta debe ser ABSOLUTA y apuntar a un
# volumen persistente (p.ej. /var/lib/portal-a3sides/uploads). Con
# ruta relativa dentro de un contenedor Docker sin volume mount, los
# archivos subidos se pierden al reiniciar. El portal registra un
# warning visible en los logs si UPLOAD_DIR no es absoluta.
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB="10"

# --- iRecursos (integracion) ---
IRECURSOS_BASE_URL="https://a3sides.irecursos.net/admin2"
IRECURSOS_USER=""
IRECURSOS_PASSWORD=""
IRECURSOS_TIMEOUT_MS="15000"
