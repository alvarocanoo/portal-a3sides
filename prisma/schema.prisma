generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  CLIENT
  AGENT
  ADMIN
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  WAITING_THIRD_PARTY
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Users & Companies ──────────────────────────────────

model Company {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  taxId             String?
  irecursosClientId String?  @unique
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Cache de contratos/productos consultados a iRecursos para esta
  // empresa. Reduce llamadas a iRecursos (que tiene límite de sesiones
  // concurrentes) cuando varios clientes de la misma empresa abren el
  // formulario de nueva incidencia. TTL controlado en código
  // (src/lib/irecursos/contracts-cache.ts). Se invalida al cambiar
  // irecursosClientId.
  cachedContracts   Json?
  cachedContractsAt DateTime?

  users     User[]
  incidents Incident[]

  @@index([irecursosClientId])
  @@map("companies")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  passwordHash       String
  role               Role      @default(CLIENT)
  firstName          String
  lastName           String
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  companyId String?  @db.Uuid
  company   Company? @relation(fields: [companyId], references: [id])

  createdIncidents  Incident[]     @relation("IncidentCreator")
  assignedIncidents Incident[]     @relation("IncidentAssignee")
  messages          Message[]
  attachments       Attachment[]
  statusChanges     StatusChange[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([companyId])
  @@index([role])
  @@map("users")
}

// ─── Incidents ──────────────────────────────────────────

model Incident {
  id          String         @id @default(uuid()) @db.Uuid
  reference   String         @unique
  subject     String
  description String
  status      IncidentStatus @default(OPEN)
  priority    Priority       @default(MEDIUM)
  category    String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?

  companyId    String  @db.Uuid
  company      Company @relation(fields: [companyId], references: [id])
  createdById  String  @db.Uuid
  createdBy    User    @relation("IncidentCreator", fields: [createdById], references: [id])
  assignedToId String? @db.Uuid
  assignedTo   User?   @relation("IncidentAssignee", fields: [assignedToId], references: [id])

  irecursosCaseId String?
  irecursosOtId   String?
  // lastSyncedAt: campo previsto para sincronizar Incident ↔ iRecursos.
  // NO se usa hoy en ningún sitio del código (siempre NULL). Decisión
  // documentada en CLAUDE.md §8.2 (Decisiones arquitectónicas vivas).
  // Si se implementa la sincronización en el futuro, USAR este campo
  // — no añadir uno nuevo.
  lastSyncedAt    DateTime?

  messages      Message[]
  attachments   Attachment[]
  statusChanges StatusChange[]

  @@index([companyId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([createdById])
  @@index([createdAt])
  @@index([irecursosCaseId])
  @@map("incidents")
}

// ─── Messages ───────────────────────────────────────────

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  incidentId String   @db.Uuid
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  authorId   String   @db.Uuid
  author     User     @relation(fields: [authorId], references: [id])

  attachments Attachment[]

  @@index([incidentId])
  @@index([authorId])
  @@map("messages")
}

// ─── Attachments ────────────────────────────────────────

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  fileName   String
  fileSize   Int
  mimeType   String
  storageKey String
  createdAt  DateTime @default(now())

  incidentId   String?   @db.Uuid
  incident     Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  messageId    String?   @db.Uuid
  message      Message?  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedById String    @db.Uuid
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])

  @@index([incidentId])
  @@index([messageId])
  @@map("attachments")
}

// ─── Audit Trail ────────────────────────────────────────

model StatusChange {
  id         String         @id @default(uuid()) @db.Uuid
  fromStatus IncidentStatus
  toStatus   IncidentStatus
  reason     String?
  createdAt  DateTime       @default(now())

  incidentId  String   @db.Uuid
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  changedById String   @db.Uuid
  changedBy   User     @relation(fields: [changedById], references: [id])

  @@index([incidentId])
  @@index([createdAt])
  @@map("status_changes")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Counters ───────────────────────────────────────────

model IncidentCounter {
  id    String @id @default("singleton")
  year  Int
  count Int    @default(0)

  @@map("incident_counters")
}

// ─── Notification Attempts (visibilidad de fallos SMTP) ─
//
// Una fila por intento de envío (éxito o fallo). Permite que el ADMIN
// vea desde el dashboard si una caída de SMTP está silenciando avisos
// a clientes/agentes. Sin esto, el portal cae en "fallo silencioso":
// el handler ya devolvió 201 al cliente, console.error es invisible
// en prod, y nadie se entera hasta que un cliente se queja.
//
// kind:       "incident.created" | "message.new" | "status.changed" | "assigned"
// recipient:  email destino del envío
// status:     "sent" | "failed"
// error:      mensaje del error si status="failed", null si "sent"
// incidentId: ref opcional para enriquecer la vista
//
// NO reintentos automáticos en esta iteración — solo visibilidad. Para
// reenviar, el admin tiene info del kind/recipient/incidentId para
// actuar manualmente. Una cola con worker (BullMQ) sería el paso
// siguiente cuando haya Redis disponible.
model NotificationAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  kind       String
  recipient  String
  status     String
  error      String?
  incidentId String?  @db.Uuid
  createdAt  DateTime @default(now())

  // Index principal: queries del dashboard filtran por status + ventana
  // de tiempo (count de "failed en últimas 24h"). Con este compuesto
  // el escaneo es directo aunque la tabla crezca.
  @@index([status, createdAt])
  @@index([incidentId])
  @@map("notification_attempts")
}

// ─── Login Attempts (rate limit por email) ──────────────
//
// Una fila por intento de login fallido. Usada por el authorize de
// NextAuth (src/lib/auth/config.ts) para implementar lockout 5×15min
// por email.
//
// Reglas:
//   - Solo se registra el fallo si el email corresponde a un usuario
//     REAL y ACTIVO (evita DoS contra emails enumerados/desactivados).
//   - Cuando un login es exitoso, se borran TODAS las filas de ese
//     email — el acierto resetea el contador (no se penaliza al
//     usuario legítimo que falló 1-2 veces antes de acertar).
//
// Limpieza: por el patrón anterior, solo crecen filas para emails que
// nunca acabaron logueándose (ataques que no entraron). Con el índice
// compuesto, las queries siguen rápidas incluso con millones de filas.
// Si en el futuro la tabla pasa de ~100k filas, un cron diario que
// borre createdAt < NOW() - 1 hora es trivial. No lo añadimos ahora.
model LoginAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  createdAt DateTime @default(now())

  // Índice compuesto: las queries de lockout filtran por email + ventana.
  // Sin esto, el count escanea tabla completa.
  @@index([email, createdAt])
  @@map("login_attempts")
}
